{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm rebuild @tailwindcss/oxide && npx prisma generate && next build"
  },
  "deploy": {
    "startCommand": "npx next start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
